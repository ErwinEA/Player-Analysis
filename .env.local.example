NEXT_PUBLIC_API_URL=http://localhost:8000

# Set to 1 to bake track ellipses into an annotated MP4 during Analyze (slower; needs ffmpeg on backend)
# NEXT_PUBLIC_RENDER_ANALYZE_VIDEO=0

# Legacy upload pipeline (backend only)
# MAX_UPLOAD_MB=4096
# MAX_FRAMES=6000
# INCLUDE_MASKS_IN_API=1  # return mask_rle for player overlay (default on)
# SAM_STRIDE=3  # run MobileSAM every N visible frames after warmup (1 = every frame)
# SAM_DEVICE=mps
# JERSEY_CLS_DEVICE=mps
# TRACKER_TYPE=botsort
# TRACK_BUFFER=120
# REID_FALLBACK_MAX_CENTER_FRAC=0.6
# REID_FALLBACK_THRESH=0.55
# REID_FALLBACK_MARGIN=0.05
# Start backend with these set: ./scripts/dev_backend.sh

# ReID (backend legacy analyzer — auto-loads detection_test/weights/osnet_x1_0_soccernet.pth)
# REID_WEIGHTS=detection_test/weights/osnet_x1_0_soccernet.pth
